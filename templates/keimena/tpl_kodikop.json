  "render_template": "<h1>ΚΩΔΙΚΟΠΟΙΗΣΗ</h1>{% if vasiko_keimeno %}<p><strong>Βασικό κείμενο:</strong> {{ vasiko_keimeno }}</p>{% endif %}{% if eidos %}<p><strong>Είδος:</strong> {{ eidos }}</p>{% endif %}{% if enim_eos %}<p><strong>Ενημ. έως:</strong> {{ enim_eos }}</p>{% endif %}{% for c in children %}{{ c }}{% endfor %}{% if paragomeno %}<hr/><p>{{ paragomeno }}</p>{% endif %}",
  "metadata": {"folder": "keimena", "folder_label": "Κείμενα", "folder_order": 3}
