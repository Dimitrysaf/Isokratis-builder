{
  "template_id": "tpl_arthro",
  "name": "Άρθρο",
  "description": "Βασική νομοθετική μονάδα.",
  "fields": [
    {
      "field_id": "arithmos",
      "label": "Αριθμός",
      "field_type": "text",
      "required": false,
      "default_value": "",
      "options": [],
      "help_text": "π.χ. 5, 5Α, 12"
    },
    {
      "field_id": "titlos",
      "label": "Τίτλος (προαιρετικό)",
      "field_type": "text",
      "required": false,
      "default_value": "",
      "options": [],
      "help_text": "π.χ. Ορισμοί, Σκοπός"
    },
    {
      "field_id": "katastasi",
      "label": "Κατάσταση",
      "field_type": "select",
      "required": false,
      "default_value": "Ισχύον",
      "options": [
        {"label": "Ισχύον",          "value": "Ισχύον"},
        {"label": "Καταργηθέν",      "value": "Καταργηθέν"},
        {"label": "Αντικατασταθέν",  "value": "Αντικατασταθέν"},
        {"label": "Τροποποιηθέν",    "value": "Τροποποιηθέν"},
        {"label": "Προστεθέν",       "value": "Προστεθέν"}
      ],
      "help_text": ""
    },
    {
      "field_id": "me_vasi",
      "label": "Με βάση (αν δεν Ισχύον)",
      "field_type": "text",
      "required": false,
      "default_value": "",
      "options": [],
      "help_text": "π.χ. άρθρο 40 του ν. 5000/2024"
    }
  ],
  "child_slots": [
    {
      "slot_id": "periexomeno",
      "label": "Παράγραφοι",
      "allowed_template_ids": ["tpl_paragrafos"],
      "allowed_folders": [],
      "min_count": 0,
      "max_count": 0
    }
  ],
  "render_template": "<h3>Άρθρο {{ arithmos }}{% if titlos %}<br/><span style=\"font-weight:normal\">{{ titlos }}</span>{% endif %}</h3>{% if katastasi and katastasi != 'Ισχύον' %}<p><em>[{{ katastasi }}{% if me_vasi %} — {{ me_vasi }}{% endif %}]</em></p>{% endif %}{% for c in children %}{{ c }}{% endfor %}",
  "metadata": {"folder": "domika", "folder_label": "Δομικά", "folder_order": 1}
}
